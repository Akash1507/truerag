APP_ENV=local
LOG_LEVEL=DEBUG

# LLM providers — add keys for the providers you use
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
COHERE_API_KEY=

# Vector store keys (only needed if using qdrant/pinecone)
QDRANT_API_KEY=
PINECONE_API_KEY=

# Databases (matches docker-compose service names)
MONGODB_URI=mongodb://mongodb:27017
MONGODB_DATABASE=truerag
PGVECTOR_DSN=postgresql://postgres:postgres@postgres:5432/truerag

# Queue
QUEUE_BACKEND=kafka
KAFKA_BOOTSTRAP_SERVERS=kafka:9092
KAFKA_TOPIC=truerag-ingestion

# App
DEFAULT_RATE_LIMIT_RPM=1000
SEMANTIC_CACHE_TTL_HOURS=24
